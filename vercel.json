{
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "www.psicologaanacarolline.com.br"
        }
      ],
      "destination": "https://psicologaanacarolline.com.br",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets|.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
